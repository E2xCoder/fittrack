generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealCategory {
  MEAL_1
  MEAL_2
  PRE_WORKOUT
  POST_WORKOUT
  SNACK
  SHAKE
}

enum WorkoutSplit {
  ARMS_FOREARMS
  SHOULDERS_TRICEPS
  CHEST_BACK
  LEGS_ABS
  REST_DAY
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailVerified Boolean @default(false)

  calorieTarget Int?
  proteinTarget Int?
  carbTarget    Int?
  fatTarget     Int?

  meals          Meal[]
  mealPacks      MealPack[]
  mealLogs       MealLog[]
  dailyLogs      DailyLog[]
  workouts       Workout[]
  exercises      Exercise[]
  weightLogs     WeightLog[]
  progressPhotos ProgressPhoto[]
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}

model Meal {
  id           String      @id @default(cuid())
  userId       String
  name         String
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sodium       Float?
  servingSize  Float       @default(1)
  servingLabel String      @default("piece") // "piece", "g", "ml"
  ingredients  String?
  imageUrl     String?
  category     MealCategory @default(SNACK)
  isFavorite   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealLogs      MealLog[]
  mealPackItems MealPackItem[]

  @@index([userId])
}

model MealPack {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealPackItem[]

  @@index([userId])
}

model MealPackItem {
  id       String @id @default(cuid())
  packId   String
  mealId   String
  quantity Float  @default(1)

  pack MealPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  meal Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([packId])
  @@index([mealId])
}

model MealLog {
  id           String       @id @default(cuid())
  userId       String
  mealId       String?
  dailyLogId   String?
  quantity     Float        @default(1)
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  mealSnapshot Json?
  createdAt    DateTime     @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal     Meal?        @relation(fields: [mealId], references: [id], onDelete: SetNull)
  dailyLog DailyLog?    @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealId])
  @@index([dailyLogId])
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date
  totalCalories Float    @default(0)
  totalProtein  Float    @default(0)
  totalCarbs    Float    @default(0)
  totalFat      Float    @default(0)
  steps         Int      @default(0)
  water         Float    @default(0)
  sleep         Float    @default(0)
  hadWorkShift  Boolean  @default(false)
  isGymDay      Boolean  @default(false)
  createdAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealLogs MealLog[]

  @@unique([userId, date])
  @@index([userId])
}

model Workout {
  id        String       @id @default(cuid())
  userId    String
  split     WorkoutSplit @default(REST_DAY)
  notes     String?
  date      DateTime     @db.Date
  createdAt DateTime     @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([userId])
  @@index([userId, date])
}

model Exercise {
  id        String   @id @default(cuid())
  userId    String
  workoutId String
  name      String
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets    ExerciseSet[]

  @@index([userId])
  @@index([workoutId])
  @@index([userId, name])
}

model ExerciseSet {
  id         String   @id @default(cuid())
  exerciseId String
  setNumber  Int      @default(1)
  weight     Float?
  reps       Int?
  rpe        Int?     // 1-10 rate of perceived exertion
  isPR       Boolean  @default(false)
  createdAt  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  weight    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}