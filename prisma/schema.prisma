generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailVerified Boolean @default(false)

  calorieTarget Int?
  proteinTarget Int?
  carbTarget    Int?
  fatTarget     Int?
  height        Float?
  weight        Float?
  stepTarget    Int?    @default(10000)
  waterTarget   Float?  @default(2.5)
  sleepTarget   Float?  @default(8)
  apiToken      String? @unique

  role                String   @default("USER")

  onboardingCompleted Boolean  @default(false)
  age                 Int?
  gender              String?
  activityLevel       String?
  goal                String?
  dietaryPreferences  String[]
  mealsPerDay         Int?     @default(3)

  meals              Meal[]
  mealPacks          MealPack[]
  mealLogs           MealLog[]
  mealCategories     UserMealCategory[]
  dailyLogs          DailyLog[]
  workouts           Workout[]
  exercises          Exercise[]
  userSplits         UserSplit[]
  bodyLogs           BodyLog[]
  weightLogs         WeightLog[]
  progressPhotos     ProgressPhoto[]
  sessions           Session[]
  accounts           Account[]
  pushSubscriptions  PushSubscription[]

  @@map("user")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserMealCategory {
  id         String   @id @default(cuid())
  userId     String
  name       String
  emoji      String   @default("🍽️")
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals Meal[]

  @@index([userId])
}

model BodyLog {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  weight         Float?
  steps          Int?
  water          Float?
  sleep          Float?
  waist          Float?
  chest          Float?
  hip            Float?
  arm            Float?
  leg            Float?
  bodyFat        Float?
  caloriesBurned Float?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model UserSplit {
  id         String   @id @default(cuid())
  userId     String
  name       String
  emoji      String   @default("🏋️")
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Meal {
  id           String  @id @default(cuid())
  userId       String
  name         String
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sodium       Float?
  servingSize  Float   @default(1)
  servingLabel String  @default("piece")
  ingredients  String?
  imageUrl     String?
  orderIndex   Int      @default(0)
  categoryId   String?
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      UserMealCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  mealLogs      MealLog[]
  mealPackItems MealPackItem[]

  @@index([userId])
  @@index([categoryId])
}

model MealPack {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealPackItem[]

  @@index([userId])
}

model MealPackItem {
  id       String @id @default(cuid())
  packId   String
  mealId   String
  quantity Float  @default(1)

  pack MealPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  meal Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([packId])
  @@index([mealId])
}

model MealLog {
  id         String   @id @default(cuid())
  userId     String
  mealId     String?
  dailyLogId String?
  quantity   Float    @default(1)
  calories   Float
  protein    Float
  carbs      Float
  fat        Float
  mealSnapshot Json?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal     Meal?     @relation(fields: [mealId], references: [id], onDelete: SetNull)
  dailyLog DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealId])
  @@index([dailyLogId])
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date
  totalCalories Float    @default(0)
  totalProtein  Float    @default(0)
  totalCarbs    Float    @default(0)
  totalFat      Float    @default(0)
  steps         Int      @default(0)
  water         Float    @default(0)
  sleep         Float    @default(0)
  hadWorkShift  Boolean  @default(false)
  isGymDay      Boolean  @default(false)
  gymSplit      String?
  createdAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealLogs MealLog[]

  @@unique([userId, date])
  @@index([userId])
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  split     String   @default("Rest Day")
  notes     String?
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([userId])
  @@index([userId, date])
}

model Exercise {
  id         String   @id @default(cuid())
  userId     String
  workoutId  String
  name       String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets    ExerciseSet[]

  @@index([userId])
  @@index([workoutId])
  @@index([userId, name])
}

model ExerciseSet {
  id         String   @id @default(cuid())
  exerciseId String
  setNumber  Int      @default(1)
  weight     Float?
  reps       Int?
  sets       Int?     @default(1)
  rpe        Int?
  isPR       Boolean  @default(false)
  createdAt  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  weight    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}