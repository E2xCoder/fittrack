generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  SHAKE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailVerified Boolean @default(false)

  meals          Meal[]
  mealLogs       MealLog[]
  dailyLogs      DailyLog[]
  workouts       Workout[]
  exercises      Exercise[]
  weightLogs     WeightLog[]
  progressPhotos ProgressPhoto[]

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Meal {
  id String @id @default(cuid())

  name String

  calories Float
  protein  Float
  carbs    Float
  fat      Float

  fiber  Float?
  sodium Float?

  servingSize  Float  @default(1)
  servingLabel String @default("serving")

  ingredients String?
  imageUrl    String?

  mealType MealType

  isFavorite Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mealLogs MealLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model MealLog {
  id String @id @default(cuid())

  quantity Float @default(1)

  calories Float
  protein  Float
  carbs    Float
  fat      Float

  mealSnapshot Json?

  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyLogId String?
  dailyLog   DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([mealId])
  @@index([userId])
  @@index([dailyLogId])
}

model DailyLog {
  id String @id @default(cuid())

  date DateTime @default(now())

  totalCalories Float @default(0)
  totalProtein  Float @default(0)
  totalCarbs    Float @default(0)
  totalFat      Float @default(0)

  steps Int   @default(0)
  water Float @default(0)
  sleep Float @default(0)

  hadWorkShift Boolean @default(false)
  isGymDay     Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mealLogs MealLog[]

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

model Workout {
  id String @id @default(cuid())

  title String
  notes String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exercises Exercise[]

  createdAt DateTime @default(now())

  @@index([userId])
}

model Exercise {
  id String @id @default(cuid())

  name String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  sets ExerciseSet[]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([workoutId])
}

model ExerciseSet {
  id String @id @default(cuid())

  weight Float?
  reps   Int?

  isPR Boolean @default(false)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([exerciseId])
}

model WeightLog {
  id String @id @default(cuid())

  weight Float

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model ProgressPhoto {
  id String @id @default(cuid())

  imageUrl String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ipAddress String? @db.Text
  userAgent String? @db.Text

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id String @id

  accountId  String @db.Text
  providerId String @db.Text

  userId String

  accessToken  String? @db.Text
  refreshToken String? @db.Text
  idToken      String? @db.Text

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String? @db.Text
  password String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id String @id

  identifier String @db.Text
  value      String @db.Text

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
